{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Backend: Install dependencies",
            "type": "shell",
            "command": "uv",
            "args": [
                "pip",
                "install",
                "-e",
                "."
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Backend: Compile check",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "python",
                "-m",
                "compileall",
                "app"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "reuse"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^([^\\s].*):([0-9]+):([0-9]+):\\s+(error|warning):\\s+(.*)$",
                    "file": 1,
                    "location": 2,
                    "message": 5
                }
            }
        },
        {
            "label": "Backend: Run tests",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "pytest",
                "tests/",
                "-v"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Backend: Run tests with coverage",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "pytest",
                "tests/",
                "-v",
                "--cov=app",
                "--cov-report=html"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Backend: Lint with ruff",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "ruff",
                "check",
                "app",
                "--show-fixes"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "reuse"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Backend: Format with ruff",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "ruff",
                "format",
                "app"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "reuse"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Backend: Type check with mypy",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "mypy",
                "app",
                "--pretty"
            ],
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "reuse"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Backend: All checks (compile + lint + type)",
            "type": "shell",
            "command": "uv run python -m compileall app && uv run ruff check app && uv run mypy app --pretty",
            "options": {
                "shell": {
                    "executable": "powershell",
                    "args": [
                        "-NoProfile",
                        "-Command"
                    ]
                }
            },
            "cwd": "${workspaceFolder}/backend",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Build backend image",
            "type": "shell",
            "command": "docker",
            "args": [
                "build",
                "-t",
                "camera-car-ocr:backend-latest",
                "-f",
                "backend/Dockerfile",
                "."
            ],
            "cwd": "${workspaceFolder}",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Compose up",
            "type": "shell",
            "command": "docker-compose",
            "args": [
                "up",
                "--build"
            ],
            "cwd": "${workspaceFolder}",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}