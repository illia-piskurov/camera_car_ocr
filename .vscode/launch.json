{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend (uv run)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.api_server:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Pipeline (uv run)",
            "type": "python",
            "request": "launch",
            "module": "app.orchestrator",
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Tests (pytest)",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v",
                "--tb=short"
            ],
            "jinja": true,
            "justMyCode": false,
            "cwd": "${workspaceFolder}/backend",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Backend with env file",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.api_server:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}/backend",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/backend"
            },
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Backend + Frontend",
            "configurations": [
                "Backend (uv run)"
            ],
            "stopAll": true
        }
    ]
}