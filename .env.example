# --- Compose ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend public API URL (used in browser) ---
NEXT_PUBLIC_BACKEND_API_BASE=http://localhost:8000

# --- Backend settings ---
CAMERA_SNAPSHOT_URL=http://<camera-host>/ISAPI/Streaming/channels/101/picture?snapShotImageType=JPEG
CAMERA_USERNAME=<camera-user>
CAMERA_PASSWORD=<camera-pass>
CAMERA_AUTH_MODE=digest
POLL_INTERVAL_SEC=0.4
REQUEST_TIMEOUT_SEC=5.0
REQUEST_RETRIES=2

DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
OCR_MODEL=global-plates-mobile-vit-v2-model

VOTING_WINDOW_SEC=1.5
MIN_CONFIRMATIONS=3
MIN_AVG_CONFIDENCE=0.80

PLATE_COOLDOWN_SEC=10.0
GLOBAL_COOLDOWN_SEC=2.0
DRY_RUN_OPEN=1

DB_PATH=data/app.db
ONEC_SYNC_INTERVAL_HOURS=24
ONEC_STUB_FILE=onec_whitelist_stub.txt
ENABLE_FUZZY_MATCH=0

# --- Preview/debug frame ---
PREVIEW_ENABLED=1
PREVIEW_WRITE_INTERVAL_SEC=3.0
PREVIEW_JPEG_QUALITY=85
PREVIEW_IMAGE_PATH=data/preview_latest.jpg
PREVIEW_META_PATH=data/preview_meta.json

# --- Recognition snapshots on successful decisions ---
RECOGNITION_SNAPSHOT_ENABLED=1
RECOGNITION_SNAPSHOT_DIR=data/recognized
RECOGNITION_SNAPSHOT_JPEG_QUALITY=90
RECOGNITION_SNAPSHOT_MAX_FILES=500
