# --- Compose ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend public API URL (used in browser) ---
NEXT_PUBLIC_BACKEND_API_BASE=http://localhost:8000

# --- Backend settings ---
CAMERA_SNAPSHOT_URL=http://<camera-host>/ISAPI/Streaming/channels/101/picture?snapShotImageType=JPEG
CAMERA_USERNAME=<camera-user>
CAMERA_PASSWORD=<camera-pass>
CAMERA_AUTH_MODE=digest
POLL_INTERVAL_SEC=0.4
REQUEST_TIMEOUT_SEC=5.0
REQUEST_RETRIES=2

DETECTOR_MODEL=yolo-v9-t-384-license-plate-end2end
OCR_MODEL=global-plates-mobile-vit-v2-model

OCR_OPEN_THRESHOLD=0.92
OCR_EXTEND_THRESHOLD=0.80
TWO_SHOT_GAP_MS=200
TWO_SHOT_MAX_PAIRS=2

DRY_RUN_OPEN=1
BARRIER_ACTION_MODE=mock
BARRIER_HA_BASE_URL=http://192.168.100.10:8123
BARRIER_HA_TOKEN=<home-assistant-long-lived-token>
ZONE1_BARRIER_OPEN_ENTITY_ID=input_button.testovyi_shlagbaum_otkryt
ZONE1_BARRIER_CLOSE_ENTITY_ID=input_button.testovyi_shlagbaum_zakryt
ZONE1_BARRIER_CLOSE_DELAY_SEC=0
ZONE2_BARRIER_OPEN_ENTITY_ID=input_button.testovyi_shlagbaum2_otkryt
ZONE2_BARRIER_CLOSE_ENTITY_ID=input_button.testovyi_shlagbaum2_zakryt
ZONE2_BARRIER_CLOSE_DELAY_SEC=0
BARRIER_REQUEST_TIMEOUT_SEC=3.0
BARRIER_REQUEST_RETRIES=2
BARRIER_VERIFY_TLS=1
BARRIER_CLOSE_DELAY_SEC=5.0

DB_PATH=data/app.db
ONEC_SYNC_INTERVAL_HOURS=24
ONEC_PROVIDER_MODE=stub
ONEC_STUB_FILE=onec_whitelist_stub.txt
ONEC_HTTP_URL=http://<1c-host>/pps/hs/VehicleAccess/VehiclesListGet
ONEC_HTTP_TIMEOUT_SEC=10
ONEC_HTTP_RETRIES=2
ONEC_HTTP_ALLOW_EMPTY_SYNC=0
ENABLE_FUZZY_MATCH=0

# --- Preview/debug frame ---
PREVIEW_ENABLED=1
PREVIEW_WRITE_INTERVAL_SEC=1.0
PREVIEW_JPEG_QUALITY=85
PREVIEW_IMAGE_PATH=data/preview_latest.jpg
PREVIEW_META_PATH=data/preview_meta.json

# --- Recognition snapshots on successful decisions ---
RECOGNITION_SNAPSHOT_ENABLED=1
RECOGNITION_SNAPSHOT_DIR=data/recognized
RECOGNITION_SNAPSHOT_JPEG_QUALITY=90
RECOGNITION_SNAPSHOT_MAX_FILES=500
